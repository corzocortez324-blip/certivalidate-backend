{
  "name": "certivalidate-backend",
  "version": "1.1.0",
  "description": "API REST para emisión y verificación de certificados digitales",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node prisma/seed.js",
    "postinstall": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "dotenv -e .env -- prisma migrate dev",
    "migrate:reset": "dotenv -e .env -- prisma migrate reset",
    "lint": "eslint src/",
    "test": "jest --runInBand --detectOpenHandles --testPathIgnorePatterns=node_modules"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.12.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2"
  }
}
