# Base de datos
# Supabase: usar puerto 6543 (pooler) en DATABASE_URL y puerto 5432 (directo) en DIRECT_URL
# PostgreSQL local: ambas pueden ser la misma URL
DATABASE_URL="postgresql://usuario:clave@localhost:5432/certivalidate"
DIRECT_URL="postgresql://usuario:clave@localhost:5432/certivalidate"

# Servidor
PORT=3000
NODE_ENV=development

# CORS — origen permitido por el frontend
FRONTEND_URL=http://localhost:5173

LOG_LEVEL=info
ENABLE_SWAGGER=false

# URL pública para verificación de certificados (aparece en los PDFs generados)
PUBLIC_VERIFY_URL=http://localhost:5173/verificar

# Resend — envío de emails transaccionales
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Para pruebas sin dominio propio usa: onboarding@resend.dev
# En producción usa tu dominio verificado: noreply@tudominio.com
EMAIL_FROM="onboarding@resend.dev"

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="una_clave_larga_y_segura_minimo_32_caracteres"
JWT_REFRESH_SECRET="otra_clave_diferente_larga_y_segura"
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Clave de cifrado AES-256 — generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="64_caracteres_hex_aqui"
